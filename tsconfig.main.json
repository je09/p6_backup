{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "target": "ES2020",
        "outDir": "./dist"
    },
    "include": [
        "src/main/**/*",
        "src/shared/**/*",
        "src/declarations.d.ts"
    ],
    // The preload is bundled by webpack instead — see tsconfig.preload.json.
    "exclude": [
        "src/main/preload.ts"
    ]
}