{
  "name": "roland-p6-backup-tool",
  "version": "0.7.4",
  "description": "A desktop application for backing up and restoring Roland P6 patterns and samples",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && webpack --mode production",
    "build:dev": "tsc -p tsconfig.main.json && webpack --mode development",
    "dev": "concurrently \"tsc -p tsconfig.main.json -w\" \"webpack --mode development --watch\" \"wait-on dist/main/main.js && electron .\"",
    "dev:debug": "concurrently \"tsc -p tsconfig.main.json -w\" \"webpack --mode development --watch\" \"wait-on dist/main/main.js && electron --inspect=5858 .\"",
    "start": "electron .",
    "start:debug": "electron --inspect=5858 .",
    "debug:main": "electron --inspect=5858 dist/main/main.js",
    "debug:renderer": "webpack serve --mode development --open",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest",
    "clean": "rimraf dist .webpack"
  },
  "keywords": [
    "roland",
    "p6",
    "backup",
    "music",
    "electron",
    "typescript"
  ],
  "author": "je09",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^6.8.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8.45.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.6.0",
    "jest-environment-jsdom": "^30.3.0",
    "rimraf": "^6.0.1",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.3",
    "wait-on": "^7.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "dependencies": {
    "@sakun/system.css": "^0.1.11",
    "@types/usb": "^2.0.5",
    "lucide-react": "^0.263.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "usb": "^2.15.0"
  },
  "build": {
    "appId": "com.je09.p6backup",
    "productName": "P6 BackupTool",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "assets/**/*",
      "!node_modules/usb/build/**"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/app.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "linux": {
      "icon": "assets/icons/",
      "category": "Utility",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
